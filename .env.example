# AlphaClaw + Kumo Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run: docker compose up

# --- Required ---
SETUP_PASSWORD=changeme
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub (for workspace sync) ---
# GITHUB_TOKEN=ghp_...
# GITHUB_WORKSPACE_REPO=owner/repo

# --- Channels (at least one recommended) ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# --- AI Providers (additional) ---
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Kumo AI Firewall ---
# KUMO_ENABLED=true          # Set to 'false' to disable Kumo
# KUMO_MODE=observe           # 'observe' (log only) or 'enforce' (apply policy)
# KUMO_POLICY_PATH=           # Path to policy YAML (required in enforce mode)
# KUMO_DATA_DIR=/data/kumo    # Where CA certs and traffic logs are stored

# --- Advanced ---
# TRUST_PROXY_HOPS=1
# PORT=3000
